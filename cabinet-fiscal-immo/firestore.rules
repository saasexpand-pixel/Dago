rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Lecture et écriture ouvertes — le filtrage published/isActive est fait côté JS
    match /articles/{id} {
      allow read, write: if true;
    }

    match /testimonials/{id} {
      allow read, write: if true;
    }

  }
}
